; ============================================================
;  WiFi-Zugangsdaten – Vorlage
;  Datei kopieren nach secrets.ini und Zugangsdaten eintragen.
;  secrets.ini wird NICHT ins Git eingecheckt!
; ============================================================
[env]
build_flags =
    -DWIFI_SSID=\"Dein-WLAN-Name\"
    -DWIFI_PASSWORD=\"Dein-WLAN-Passwort\"
